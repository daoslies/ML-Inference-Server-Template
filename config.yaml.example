# Example configuration for ML__Inference_Server_Template
# Copy this file to config.yaml and edit as needed

server:
  port: 27776
  debug: false
  host: 0.0.0.0

model:
  n_ctx: 4096
  n_threads: 16
  n_gpu_layers: -1
  verbose: false

defaults:
  prompts_path: prompts.yaml

llama_cpp:
  server_bin: /absolute/path/to/llama-server  # Path to the llama-server binary (required to use gguf)
  server_port: 8000                           # Port for llama-server to listen on (required to use gguf)
